{
  "name": "huckleberry-js",
  "version": "0.1.0",
  "description": "Unofficial read-only TypeScript client for the Huckleberry baby-tracking app (Firebase). Runs on Cloudflare Workers, Node 18+, and browsers. Not affiliated with Huckleberry Labs.",
  "type": "module",
  "license": "MIT",
  "author": "RobErskine",
  "homepage": "https://github.com/RobErskine/huckleberry-js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RobErskine/huckleberry-js.git"
  },
  "bugs": {
    "url": "https://github.com/RobErskine/huckleberry-js/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md", "LICENSE"],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "node scripts/smoke.mjs",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test"
  },
  "keywords": ["huckleberry", "baby", "firebase", "firestore", "cloudflare", "workers"],
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
