{
  "name": "huckleberry-js",
  "version": "0.2.0",
  "description": "Unofficial read-only TypeScript client for the Huckleberry baby-tracking app (Firebase). Runs on Cloudflare Workers, Node 18+, and browsers. Not affiliated with Huckleberry Labs.",
  "type": "module",
  "license": "MIT",
  "author": "RobErskine",
  "homepage": "https://github.com/RobErskine/huckleberry-js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RobErskine/huckleberry-js.git"
  },
  "bugs": {
    "url": "https://github.com/RobErskine/huckleberry-js/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mcp/worker": {
      "types": "./dist/mcp/worker.d.ts",
      "import": "./dist/mcp/worker.js"
    },
    "./mcp/tools": {
      "types": "./dist/mcp/tools.d.ts",
      "import": "./dist/mcp/tools.js"
    }
  },
  "bin": {
    "huckleberry-mcp": "./dist/mcp/stdio.js"
  },
  "files": ["dist", "src", "README.md", "LICENSE"],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "node scripts/smoke.mjs",
    "mcp": "node dist/mcp/stdio.js",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test"
  },
  "keywords": [
    "huckleberry",
    "baby",
    "firebase",
    "firestore",
    "cloudflare",
    "workers",
    "mcp",
    "model-context-protocol"
  ],
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
